<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Modular.Gui.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="700"
             x:Class="Modular.Gui.Views.SwitchInstallView"
             x:DataType="vm:SwitchInstallViewModel">

    <Design.DataContext>
        <vm:SwitchInstallViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="20" MaxWidth="700">
            <!-- Yuzu Path Setting -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <mi:MaterialIcon Kind="FolderCog" Width="24" Height="24"/>
                        <TextBlock Text="Yuzu Data Directory" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Path to Yuzu's data directory (contains the 'load' folder for LayeredFS mods)"
                               Opacity="0.6" TextWrapping="Wrap"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" Text="{Binding YuzuDataRoot}"
                                 Watermark="e.g. ~/.local/share/yuzu"/>
                        <Button Grid.Column="1" Content="Browse..." Margin="10,0,0,0"
                                Command="{Binding BrowseYuzuPathCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Source Folder & Scan -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                            <mi:MaterialIcon Kind="FolderSearch" Width="24" Height="24"/>
                            <TextBlock Text="Install from Folder" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ScanFolderCommand}"
                                IsEnabled="{Binding !IsScanning}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <mi:MaterialIcon Kind="Magnify" Width="14" Height="14"/>
                                <TextBlock Text="Scan"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock Text="Select a folder containing Switch mod archives (.zip, .7z, .rar) or extracted mod folders"
                               Opacity="0.6" TextWrapping="Wrap"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" Text="{Binding SourceFolder}"
                                 Watermark="Folder containing Switch mod archives"/>
                        <Button Grid.Column="1" Content="Browse..." Margin="10,0,0,0"
                                Command="{Binding BrowseSourceFolderCommand}"/>
                    </Grid>

                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsScanning}"/>
                </StackPanel>
            </Border>

            <!-- Discovered Mods -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="20"
                    IsVisible="{Binding DiscoveredMods.Count}">
                <StackPanel Spacing="15">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                            <mi:MaterialIcon Kind="GamepadVariant" Width="24" Height="24"/>
                            <TextBlock Text="Discovered Mods" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DiscoveredMods.Count, StringFormat='({0})'}"
                                       VerticalAlignment="Center" Opacity="0.6"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding SelectAllCommand}"
                                ToolTip.Tip="Select all uninstalled" Margin="0,0,5,0">
                            <TextBlock Text="Select All" FontSize="12"/>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding SelectNoneCommand}"
                                ToolTip.Tip="Deselect all">
                            <TextBlock Text="Select None" FontSize="12"/>
                        </Button>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding DiscoveredMods}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SwitchModDisplayModel">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                                        CornerRadius="4" Padding="10,8" Margin="0,2">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                  IsEnabled="{Binding !IsInstalled}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Version}" Opacity="0.6" FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Text="{Binding TitleId}" FontSize="11"
                                                           FontFamily="Consolas" Opacity="0.5"/>
                                                <TextBlock Text="{Binding Category}" FontSize="11" Opacity="0.5"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="Installed" Opacity="0.5" FontSize="12"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding IsInstalled}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Install Button -->
                    <Button Command="{Binding InstallSelectedCommand}"
                            IsEnabled="{Binding !IsInstalling}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="15,12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="PackageDown" Width="20" Height="20"/>
                            <TextBlock Text="Install Selected Mods" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <StackPanel IsVisible="{Binding IsInstalling}" Spacing="5">
                        <ProgressBar Value="{Binding InstallProgress}" Minimum="0" Maximum="100"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Install Results -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="15"
                    IsVisible="{Binding InstallResults.Count}">
                <StackPanel Spacing="5">
                    <TextBlock Text="Results" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ItemsControl ItemsSource="{Binding InstallResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12" FontFamily="Consolas" Opacity="0.8"
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Installed Switch Mods -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                            <mi:MaterialIcon Kind="PackageCheck" Width="24" Height="24"/>
                            <TextBlock Text="Installed Switch Mods" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding InstalledMods.Count, StringFormat='({0})'}"
                                       VerticalAlignment="Center" Opacity="0.6"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding RefreshInstalledCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <mi:MaterialIcon Kind="Refresh" Width="14" Height="14"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock Text="No Switch mods installed"
                               Opacity="0.5" IsVisible="{Binding !InstalledMods.Count}"/>

                    <ItemsControl ItemsSource="{Binding InstalledMods}"
                                  IsVisible="{Binding InstalledMods.Count}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SwitchModDisplayModel">
                                <Border Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                                        CornerRadius="4" Padding="10,8" Margin="0,2">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Version}" Opacity="0.6" FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Text="{Binding TitleId}" FontSize="11"
                                                           FontFamily="Consolas" Opacity="0.5"/>
                                                <TextBlock Text="{Binding Category}" FontSize="11" Opacity="0.5"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Command="{Binding $parent[ItemsControl].((vm:SwitchInstallViewModel)DataContext).RemoveModCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="Remove this mod" Padding="6,4">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <mi:MaterialIcon Kind="Delete" Width="14" Height="14"/>
                                                <TextBlock Text="Remove" FontSize="12"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}" Opacity="0.7"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>

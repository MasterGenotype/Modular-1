<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Modular.Gui.ViewModels"
             xmlns:views="using:Modular.Gui.Views"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Modular.Gui.Views.ModManagerView"
             x:DataType="vm:ModManagerViewModel">

    <Design.DataContext>
        <vm:ModManagerViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Status bar -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Opacity="0.7" Margin="0,10,0,0"/>

        <TabControl SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="PackageDown" Width="16" Height="16"/>
                        <TextBlock Text="Install"/>
                    </StackPanel>
                </TabItem.Header>
                <views:InstallView DataContext="{Binding InstallViewModel}"/>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="PackageCheck" Width="16" Height="16"/>
                        <TextBlock Text="Installed"/>
                    </StackPanel>
                </TabItem.Header>
                <views:InstalledModsView DataContext="{Binding InstalledModsViewModel}"/>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="NintendoSwitch" Width="16" Height="16"/>
                        <TextBlock Text="Switch"/>
                    </StackPanel>
                </TabItem.Header>
                <views:SwitchInstallView DataContext="{Binding SwitchInstallViewModel}"/>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Modular.Gui.ViewModels"
             xmlns:views="using:Modular.Gui.Views"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Modular.Gui.Views.NexusModsView"
             x:DataType="vm:NexusModsViewModel">

    <Design.DataContext>
        <vm:NexusModsViewModel/>
    </Design.DataContext>

    <TabControl SelectedIndex="{Binding SelectedTabIndex}">
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="Magnify" Width="16" Height="16"/>
                    <TextBlock Text="Search"/>
                </StackPanel>
            </TabItem.Header>
            <views:NexusSearchView DataContext="{Binding NexusSearchViewModel}"/>
        </TabItem>

        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="Star" Width="16" Height="16"/>
                    <TextBlock Text="Tracked Mods"/>
                </StackPanel>
            </TabItem.Header>
            <views:ModListView DataContext="{Binding ModListViewModel}"/>
        </TabItem>
    </TabControl>
</UserControl>

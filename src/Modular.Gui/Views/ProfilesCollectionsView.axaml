<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Modular.Gui.ViewModels"
             xmlns:views="using:Modular.Gui.Views"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Modular.Gui.Views.ProfilesCollectionsView"
             x:DataType="vm:ProfilesCollectionsViewModel">

    <Design.DataContext>
        <vm:ProfilesCollectionsViewModel/>
    </Design.DataContext>

    <views:ProfilesView DataContext="{Binding ProfilesViewModel}"/>
</UserControl>

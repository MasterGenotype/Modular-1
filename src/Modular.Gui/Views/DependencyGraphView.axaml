<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Modular.Gui.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Modular.Gui.Views.DependencyGraphView"
             x:DataType="vm:DependencyGraphViewModel">

    <Design.DataContext>
        <vm:DependencyGraphViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Input Area -->
        <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel Spacing="10">
                <TextBlock Text="Dependency Resolver" FontWeight="SemiBold" FontSize="16"/>
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                    <TextBox Grid.Column="0" Watermark="Mod ID (e.g., nexusmods:12345)"
                             Text="{Binding NewModId}" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" Watermark="Constraint (e.g., >=1.0.0)"
                             Text="{Binding NewModConstraint}" Width="180" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Command="{Binding AddRequirementCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <mi:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                            <TextBlock Text="Add"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3" Command="{Binding ResolveCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <mi:MaterialIcon Kind="PlayCircle" Width="16" Height="16"/>
                            <TextBlock Text="Resolve"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4" Command="{Binding ClearRequirementsCommand}">
                        <mi:MaterialIcon Kind="DeleteSweep" Width="16" Height="16"/>
                    </Button>
                </Grid>
                <CheckBox Content="Include optional dependencies" IsChecked="{Binding IncludeOptional}"/>
            </StackPanel>
        </Border>

        <!-- Main Content - Three Column Layout -->
        <Grid Grid.Row="1" ColumnDefinitions="250,*,250">
            <!-- Nodes List -->
            <Border Grid.Column="0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="10" Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Dependency Nodes" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ListBox ItemsSource="{Binding Nodes}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:DependencyNodeItem">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <mi:MaterialIcon Width="16" Height="16" Opacity="0.7">
                                        <mi:MaterialIcon.Kind>
                                            <Binding Path="IsRoot">
                                                <Binding.Converter>
                                                    <x:Static Member="ObjectConverters.IsNotNull"/>
                                                </Binding.Converter>
                                            </Binding>
                                        </mi:MaterialIcon.Kind>
                                    </mi:MaterialIcon>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayLabel}" FontSize="12"/>
                                        <TextBlock Text="{Binding ConstraintStr}" FontSize="10" Opacity="0.5"
                                                   IsVisible="{Binding ConstraintStr, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Center: Edges + Install Order -->
            <Border Grid.Column="1" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="10" Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Dependency Edges" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <!-- Install Order -->
                    <Border DockPanel.Dock="Bottom" Margin="0,10,0,0"
                            IsVisible="{Binding InstallOrder.Count}">
                        <StackPanel>
                            <TextBlock Text="Install Order" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ItemsControl ItemsSource="{Binding InstallOrder}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="12" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <ListBox ItemsSource="{Binding Edges}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:DependencyEdgeItem">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding From}" FontSize="12"/>
                                    <mi:MaterialIcon Kind="ArrowRight" Width="14" Height="14" Opacity="0.5"/>
                                    <TextBlock Text="{Binding To}" FontSize="12"/>
                                    <TextBlock Text="{Binding Type}" FontSize="10" Opacity="0.5"
                                               FontStyle="Italic"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Right: Log + Conflicts -->
            <Border Grid.Column="2" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Resolution Log" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <!-- Conflicts -->
                    <Border DockPanel.Dock="Bottom" Margin="0,10,0,0"
                            IsVisible="{Binding Conflicts.Count}">
                        <StackPanel>
                            <TextBlock Text="Conflicts" FontWeight="SemiBold" Foreground="Red" Margin="0,0,0,5"/>
                            <ItemsControl ItemsSource="{Binding Conflicts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11" TextWrapping="Wrap" Foreground="OrangeRed"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <ListBox ItemsSource="{Binding ResolutionLog}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Margin="0,15,0,0" Opacity="0.7"/>
    </Grid>
</UserControl>

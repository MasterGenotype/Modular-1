<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Modular.Gui.ViewModels"
             xmlns:views="using:Modular.Gui.Views"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Modular.Gui.Views.GameBananaPanelView"
             x:DataType="vm:GameBananaPanelViewModel">

    <Design.DataContext>
        <vm:GameBananaPanelViewModel/>
    </Design.DataContext>

    <TabControl SelectedIndex="{Binding SelectedTabIndex}">
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="Star" Width="16" Height="16"/>
                    <TextBlock Text="Subscriptions"/>
                </StackPanel>
            </TabItem.Header>
            <views:GameBananaView DataContext="{Binding GameBananaViewModel}"/>
        </TabItem>

        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="Magnify" Width="16" Height="16"/>
                    <TextBlock Text="Search"/>
                </StackPanel>
            </TabItem.Header>
            <Border Padding="20">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                    <mi:MaterialIcon Kind="Magnify" Width="64" Height="64" Opacity="0.3"/>
                    <TextBlock Text="GameBanana Search" FontSize="16" Opacity="0.5" HorizontalAlignment="Center"/>
                    <TextBlock Text="Search across all GameBanana mods — coming soon" Opacity="0.3" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </TabItem>
    </TabControl>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Modular.Gui.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Modular.Gui.Views.SnapshotView"
             x:DataType="vm:SnapshotViewModel">

    <Design.DataContext>
        <vm:SnapshotViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="200,*,300">
        <!-- Left panel: Game selector + Create -->
        <Border Grid.Column="0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Margin="0,0,10,0" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Games" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="0,10,0,0">
                    <Button Command="{Binding CreateSnapshotCommand}" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" IsEnabled="{Binding SelectedGame, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <mi:MaterialIcon Kind="CameraPlus" Width="16" Height="16"/>
                            <TextBlock Text="Create Snapshot"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <ListBox ItemsSource="{Binding Games}"
                         SelectedItem="{Binding SelectedGame}"
                         Margin="0,0,0,5">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:GameDisplayModel">
                            <StackPanel Spacing="2" Margin="5">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding AppId, StringFormat='AppID: {0}'}" Opacity="0.6" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Center panel: Calendar + Day snapshots -->
        <Border Grid.Column="1" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Margin="0,0,10,0" Padding="10">
            <DockPanel>
                <!-- Month navigation -->
                <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,10">
                    <Button Grid.Column="0" Command="{Binding PreviousMonthCommand}" Background="Transparent" Padding="8,4">
                        <mi:MaterialIcon Kind="ChevronLeft" Width="20" Height="20"/>
                    </Button>
                    <TextBlock Grid.Column="1" Text="{Binding DisplayMonthName}" FontWeight="Bold" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Command="{Binding NextMonthCommand}" Background="Transparent" Padding="8,4">
                        <mi:MaterialIcon Kind="ChevronRight" Width="20" Height="20"/>
                    </Button>
                </Grid>

                <!-- Day-of-week headers -->
                <UniformGrid DockPanel.Dock="Top" Columns="7" Margin="0,0,0,5">
                    <TextBlock Text="Su" HorizontalAlignment="Center" Opacity="0.5" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="Mo" HorizontalAlignment="Center" Opacity="0.5" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="Tu" HorizontalAlignment="Center" Opacity="0.5" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="We" HorizontalAlignment="Center" Opacity="0.5" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="Th" HorizontalAlignment="Center" Opacity="0.5" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="Fr" HorizontalAlignment="Center" Opacity="0.5" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="Sa" HorizontalAlignment="Center" Opacity="0.5" FontSize="12" FontWeight="SemiBold"/>
                </UniformGrid>

                <!-- Calendar grid -->
                <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding CalendarDays}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" Rows="6"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CalendarDayModel">
                            <Button Command="{Binding $parent[ItemsControl].((vm:SnapshotViewModel)DataContext).SelectDayCommand}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" BorderThickness="0"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    Padding="2" MinHeight="36">
                                <StackPanel HorizontalAlignment="Center" Spacing="1">
                                    <TextBlock Text="{Binding DayNumber}" HorizontalAlignment="Center"
                                               FontSize="13"
                                               Opacity="{Binding DayOpacity}"
                                               FontWeight="{Binding DayFontWeight}"/>
                                    <!-- Snapshot indicator dot -->
                                    <Ellipse Width="5" Height="5" Fill="{DynamicResource SystemAccentColor}"
                                             HorizontalAlignment="Center"
                                             IsVisible="{Binding HasSnapshots}"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Separator -->
                <Separator DockPanel.Dock="Top" Margin="0,8"/>

                <!-- Day snapshots list -->
                <TextBlock DockPanel.Dock="Top" Text="Snapshots" FontWeight="SemiBold" FontSize="14" Margin="0,5,0,5"/>

                <ListBox ItemsSource="{Binding DaySnapshots}"
                         SelectedItem="{Binding SelectedSnapshot}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SnapshotDisplayModel">
                            <StackPanel Spacing="2" Margin="5">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Spacing="10" Opacity="0.6">
                                    <TextBlock Text="{Binding CreatedAt}" FontSize="11"/>
                                    <TextBlock Text="{Binding ModCount, StringFormat='{}{0} mod(s)'}" FontSize="11"/>
                                    <TextBlock Text="{Binding Trigger}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Right panel: Snapshot detail -->
        <Border Grid.Column="2" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Snapshot Detail" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                <!-- Action buttons -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
                    <Button Command="{Binding RestoreSnapshotCommand}"
                            CommandParameter="{Binding SelectedSnapshot}"
                            IsEnabled="{Binding SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <mi:MaterialIcon Kind="BackupRestore" Width="16" Height="16"/>
                            <TextBlock Text="Restore"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeleteSnapshotCommand}"
                            CommandParameter="{Binding SelectedSnapshot}"
                            IsEnabled="{Binding SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <mi:MaterialIcon Kind="Delete" Width="16" Height="16"/>
                            <TextBlock Text="Delete"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status bar -->
                <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Opacity="0.7" Margin="0,5,0,0"/>

                <!-- Loading indicator -->
                <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" IsVisible="{Binding IsLoading}" Margin="0,0,0,10"/>

                <!-- Snapshot info -->
                <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,10"
                            IsVisible="{Binding SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Text="{Binding SelectedSnapshot.Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding SelectedSnapshot.CreatedAt}" Opacity="0.7" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" Spacing="10" Opacity="0.7">
                        <TextBlock Text="{Binding SelectedSnapshot.ModCount, StringFormat='{}{0} mod(s)'}" FontSize="12"/>
                        <TextBlock Text="{Binding SelectedSnapshot.Trigger}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <!-- Entries DataGrid -->
                <DataGrid ItemsSource="{Binding SnapshotEntries}"
                          AutoGenerateColumns="False"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal"
                          IsReadOnly="True"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mod" Binding="{Binding ModId}" Width="*"/>
                        <DataGridTextColumn Header="Archive" Binding="{Binding ArchiveName}" Width="*"/>
                        <DataGridTextColumn Header="Installed" Binding="{Binding InstalledAt}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

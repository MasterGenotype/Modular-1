<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Modular.Gui.ViewModels"
             xmlns:models="using:Modular.Gui.Models"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Modular.Gui.Views.NexusSearchView"
             x:DataType="vm:NexusSearchViewModel">

    <Design.DataContext>
        <vm:NexusSearchViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
        <!-- Search bar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,15">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" Margin="0,0,10,0">
                <TextBlock Text="Game:" VerticalAlignment="Center"/>
                <AutoCompleteBox ItemsSource="{Binding AvailableGames}"
                                 Text="{Binding SelectedGame}"
                                 FilterMode="Contains"
                                 MinWidth="220"
                                 Watermark="Type or select a game domain"/>
            </StackPanel>

            <TextBox Grid.Column="1"
                     Text="{Binding SearchText}"
                     Watermark="Search mods... (leave empty to browse all)"
                     Margin="0,0,10,0">
                <TextBox.InnerLeftContent>
                    <mi:MaterialIcon Kind="Magnify" Width="16" Height="16" Margin="8,0,0,0" Opacity="0.5"/>
                </TextBox.InnerLeftContent>
            </TextBox>

            <Button Grid.Column="2" Command="{Binding ExecuteSearchCommand}"
                    ToolTip.Tip="Search">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <mi:MaterialIcon Kind="Magnify" Width="16" Height="16"/>
                    <TextBlock Text="Search"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Sort options -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
            <TextBlock Text="Sort:" VerticalAlignment="Center" Opacity="0.7"/>
            <ComboBox SelectedIndex="0" MinWidth="150"
                      SelectionChanged="OnSortChanged">
                <ComboBoxItem Content="Relevance" Tag="Relevance"/>
                <ComboBoxItem Content="Most Downloads" Tag="Downloads"/>
                <ComboBoxItem Content="Most Endorsed" Tag="Endorsements"/>
                <ComboBoxItem Content="Recently Updated" Tag="Updated"/>
                <ComboBoxItem Content="Recently Added" Tag="Added"/>
            </ComboBox>
            <CheckBox Content="Include Adult Content"
                      IsChecked="{Binding IncludeAdultContent}"
                      VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

        <!-- Selection bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
            <Button Command="{Binding SelectAllCommand}" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <mi:MaterialIcon Kind="CheckboxMultipleMarked" Width="14" Height="14"/>
                    <TextBlock Text="Select All" FontSize="12"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding SelectNoneCommand}" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <mi:MaterialIcon Kind="CheckboxMultipleBlankOutline" Width="14" Height="14"/>
                    <TextBlock Text="Select None" FontSize="12"/>
                </StackPanel>
            </Button>
            <TextBlock VerticalAlignment="Center" Opacity="0.6" FontSize="12">
                <Run Text="{Binding SelectedCount}"/>
                <Run Text=" selected"/>
            </TextBlock>
        </StackPanel>

        <!-- Results grid + detail panel -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
            <!-- Left: search results -->
            <Border Grid.Column="0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="1">
                <Grid>
                    <!-- Loading indicator -->
                    <StackPanel IsVisible="{Binding IsLoading}"
                                VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                        <ProgressBar IsIndeterminate="True" Width="200"/>
                        <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center" Opacity="0.7"/>
                    </StackPanel>

                    <!-- Status message when not loading and no results -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                        <StackPanel.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="!IsLoading"/>
                                <Binding Path="!SearchResults.Count"/>
                            </MultiBinding>
                        </StackPanel.IsVisible>
                        <mi:MaterialIcon Kind="Magnify" Width="48" Height="48" Opacity="0.3"/>
                        <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center" Opacity="0.6" FontSize="14"/>
                    </StackPanel>

                    <!-- Results DataGrid -->
                    <DataGrid ItemsSource="{Binding SearchResults}"
                              SelectedItem="{Binding SelectedMod}"
                              AutoGenerateColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal"
                              RowHeight="48"
                              IsReadOnly="False"
                              SelectionMode="Single">
                        <DataGrid.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="!IsLoading"/>
                                <Binding Path="SearchResults.Count"/>
                            </MultiBinding>
                        </DataGrid.IsVisible>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="models:ModDisplayModel">
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="" Width="52">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="models:ModDisplayModel">
                                        <Border Width="44" Height="44" Margin="2"
                                                CornerRadius="4" ClipToBounds="True"
                                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="UniformToFill"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ID" Binding="{Binding ModId}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="150" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Downloads" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="models:ModDisplayModel">
                                        <TextBlock Text="{Binding Mod.DownloadCount, StringFormat='{}{0:N0}'}"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Endorsements" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="models:ModDisplayModel">
                                        <TextBlock Text="{Binding Mod.EndorsementCount, StringFormat='{}{0:N0}'}"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Updated" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="models:ModDisplayModel">
                                        <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Right: mod detail panel (visible when a mod is selected) -->
            <Border Grid.Column="1" Margin="10,0,0,0"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="0"
                    IsVisible="{Binding SelectedMod, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Width="{Binding DetailPanelWidth}">
                <Grid RowDefinitions="Auto,*">
                    <!-- Header bar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="12,8">
                        <Button Command="{Binding OpenModPageCommand}" Padding="8,4"
                                ToolTip.Tip="Open mod page in browser">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <mi:MaterialIcon Kind="OpenInNew" Width="14" Height="14"/>
                                <TextBlock Text="Open in Browser" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Detail panel -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="10" Margin="12,0,12,12">
                            <!-- Image gallery -->
                            <Border CornerRadius="6" ClipToBounds="True" Height="200"
                                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                <Grid>
                                    <!-- Current image -->
                                    <Image Source="{Binding CurrentImage}"
                                           Stretch="Uniform"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>

                                    <!-- Loading spinner -->
                                    <ProgressBar IsIndeterminate="True" Width="80"
                                                 IsVisible="{Binding IsLoadingImage}"
                                                 VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    <!-- Navigation overlay -->
                                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Bottom"
                                          Margin="4,0,4,4">
                                        <Button Grid.Column="0" Command="{Binding PreviousImageCommand}"
                                                IsEnabled="{Binding HasPreviousImage}"
                                                Padding="6,3" Opacity="0.85"
                                                ToolTip.Tip="Previous image">
                                            <mi:MaterialIcon Kind="ChevronLeft" Width="16" Height="16"/>
                                        </Button>
                                        <TextBlock Grid.Column="1" Text="{Binding ImageLabel}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="11" Opacity="0.7"/>
                                        <Button Grid.Column="2" Command="{Binding NextImageCommand}"
                                                IsEnabled="{Binding HasNextImage}"
                                                Padding="6,3" Opacity="0.85"
                                                ToolTip.Tip="Next image">
                                            <mi:MaterialIcon Kind="ChevronRight" Width="16" Height="16"/>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Mod details (bound to SelectedMod) -->
                            <StackPanel Spacing="10" DataContext="{Binding SelectedMod}">

                            <!-- Mod name -->
                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <!-- Author -->
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="Account" Width="14" Height="14" Opacity="0.6"/>
                                <TextBlock Text="{Binding Author}" Opacity="0.8"/>
                            </StackPanel>

                            <!-- Stats row -->
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <mi:MaterialIcon Kind="Download" Width="14" Height="14" Opacity="0.6"/>
                                    <TextBlock Text="{Binding Mod.DownloadCount, StringFormat='{}{0:N0}'}"
                                               FontSize="12" Opacity="0.7"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <mi:MaterialIcon Kind="ThumbUp" Width="14" Height="14" Opacity="0.6"/>
                                    <TextBlock Text="{Binding Mod.EndorsementCount, StringFormat='{}{0:N0}'}"
                                               FontSize="12" Opacity="0.7"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Updated -->
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="CalendarClock" Width="14" Height="14" Opacity="0.6"/>
                                <TextBlock Text="{Binding UpdatedAt, StringFormat='Updated {0:yyyy-MM-dd}'}"
                                           FontSize="12" Opacity="0.7"/>
                            </StackPanel>

                            <!-- Game domain -->
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="GamepadVariant" Width="14" Height="14" Opacity="0.6"/>
                                <TextBlock Text="{Binding GameDomain}" FontSize="12" Opacity="0.7"/>
                            </StackPanel>

                            <!-- Mod ID -->
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="Identifier" Width="14" Height="14" Opacity="0.6"/>
                                <TextBlock FontSize="12" Opacity="0.7">
                                    <Run Text="Mod ID: "/>
                                    <Run Text="{Binding ModId}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Summary / Description -->
                            <TextBlock Text="{Binding Summary}" TextWrapping="Wrap"
                                       FontSize="12" Opacity="0.8"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer: pagination + download -->
        <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto" Margin="0,15,0,0">
            <!-- Results count & pagination -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Opacity="0.7">
                    <Run Text="{Binding TotalResults}"/>
                    <Run Text=" results found"/>
                </TextBlock>
                <Button Command="{Binding PreviousPageCommand}"
                        IsEnabled="{Binding HasPreviousPage}"
                        Content="Previous" Padding="8,4"/>
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Page "/>
                    <Run Text="{Binding CurrentPage}"/>
                </TextBlock>
                <Button Command="{Binding NextPageCommand}"
                        IsEnabled="{Binding HasNextPage}"
                        Content="Next" Padding="8,4"/>
            </StackPanel>

            <!-- Download Selected button -->
            <Button Grid.Column="2"
                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DownloadSelectedCommand}"
                    IsEnabled="{Binding SelectedCount}"
                    Padding="16,10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="Download" Width="18" Height="18"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Download Selected ("/>
                        <Run Text="{Binding SelectedCount}"/>
                        <Run Text=")"/>
                    </TextBlock>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
